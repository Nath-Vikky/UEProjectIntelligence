{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://uepi.local/schemas/relation.schema.json",
  "title": "UEPI Relation",
  "type": "object",
  "required": ["id", "type", "from_id", "to_id", "source_layer", "derived", "confidence", "evidence"],
  "properties": {
    "id": { "type": "string", "minLength": 64, "maxLength": 64 },
    "type": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
    "from_id": { "type": "string", "minLength": 64, "maxLength": 64 },
    "to_id": { "type": "string", "minLength": 64, "maxLength": 64 },
    "source_layer": { "$ref": "diagnostic.schema.json#/$defs/source_layer" },
    "derived": { "type": "boolean" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "attributes": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "evidence": {
      "type": "array",
      "items": { "$ref": "diagnostic.schema.json#/$defs/evidence" }
    }
  }
}
