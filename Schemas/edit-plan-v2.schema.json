{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://uepi.local/schemas/edit-plan-v2.schema.json",
  "title": "UEPI Edit Plan v2",
  "type": "object",
  "required": ["schema_version", "transaction_id", "project", "editor", "base", "operations", "operation_order", "predicted_touched_packages", "validation_plan", "save_policy", "risk", "approval", "expires_at", "plan_hash"],
  "properties": {
    "schema_version": {"const": "uepi.edit_plan.v2"},
    "transaction_id": {"type": "string", "minLength": 1},
    "project_binding_id": {"type": "string", "pattern": "^sha256:"},
    "editor_session_id": {"type": "string", "minLength": 1},
    "catalog_hash": {"type": "string", "pattern": "^sha256:"},
    "operations": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["type", "params"]}},
    "affected_assets": {"type": "array", "items": {"type": "string"}},
    "before_fingerprints": {"type": "object"},
    "expires_at": {"type": "string", "format": "date-time"},
    "approval_nonce": {"type": "string", "minLength": 1},
    "project": {"type": "object", "required": ["project_binding_id", "project_file"]},
    "editor": {"type": "object", "required": ["session_id"]},
    "base": {"type": "object", "required": ["catalog_hash", "plugin_build_id"]},
    "operation_order": {"type": "array", "items": {"type": "string"}},
    "predicted_touched_packages": {"type": "array", "items": {"type": "string"}},
    "validation_plan": {"type": "array", "items": {"type": "object"}},
    "save_policy": {"enum": ["never", "after_validation", "explicit_operation"]},
    "risk": {"type": "object"},
    "approval": {"type": "object", "required": ["required", "nonce", "plan_hash"]},
    "plan_hash": {"type": "string", "pattern": "^sha256:"}
  }
}
