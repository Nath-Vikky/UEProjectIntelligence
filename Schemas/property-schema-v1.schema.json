{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://uepi.local/schemas/property-schema-v1.schema.json",
  "title": "UEPI Property Schema v1",
  "type": "object",
  "required": ["schema_version", "type_path", "properties"],
  "properties": {
    "schema_version": {"const": "uepi.property-schema.v1"},
    "type_path": {"type": "string"},
    "properties": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "cpp_type", "property_class", "editable", "read_only", "transient"]
      }
    }
  }
}
