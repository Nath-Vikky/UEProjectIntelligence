{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://uepi.local/schemas/niagara.schema.json",
  "title": "UEPI Niagara Snapshots",
  "oneOf": [
    { "$ref": "#/$defs/niagara_system" },
    { "$ref": "#/$defs/niagara_emitter" },
    { "$ref": "#/$defs/niagara_script" },
    { "$ref": "#/$defs/vector_field_static" },
    { "$ref": "#/$defs/niagara_parameter_definitions" }
  ],
  "$defs": {
    "vector3": {
      "type": "object",
      "required": ["x", "y", "z"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "z": { "type": "number" }
      }
    },
    "niagara_parameter": {
      "type": "object",
      "required": ["index", "scope", "name", "namespace", "type", "size_bytes", "has_default_value", "default_value"],
      "properties": {
        "index": { "type": "integer", "minimum": 0 },
        "scope": { "type": "string" },
        "name": { "type": "string" },
        "namespace": { "type": "string" },
        "type": { "type": "string" },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "has_default_value": { "type": "boolean" },
        "default_value": { "type": "string" }
      }
    },
    "niagara_parameter_definition": {
      "type": "object",
      "required": [
        "id",
        "index",
        "script_variable_path",
        "name",
        "namespace",
        "type",
        "size_bytes",
        "default_mode",
        "static_switch",
        "static_switch_default_value",
        "subscribed_to_parameter_definitions",
        "overrides_parameter_definitions_default_value",
        "change_id",
        "variable_guid",
        "description",
        "category_name",
        "display_unit",
        "advanced_display",
        "display_in_overview_stack",
        "inline_parameter_sort_priority",
        "editor_sort_priority",
        "inline_edit_condition_toggle",
        "parent_attribute",
        "alternate_alias_count",
        "property_metadata_count"
      ],
      "properties": {
        "id": { "type": "string" },
        "index": { "type": "integer", "minimum": 0 },
        "script_variable_path": { "type": "string" },
        "name": { "type": "string" },
        "namespace": { "type": "string" },
        "type": { "type": "string" },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "default_mode": { "type": "string" },
        "static_switch": { "type": "boolean" },
        "static_switch_default_value": { "type": "integer" },
        "subscribed_to_parameter_definitions": { "type": "boolean" },
        "overrides_parameter_definitions_default_value": { "type": "boolean" },
        "change_id": { "type": "string" },
        "variable_guid": { "type": "string" },
        "description": { "type": "string" },
        "category_name": { "type": "string" },
        "display_unit": { "type": "string" },
        "advanced_display": { "type": "boolean" },
        "display_in_overview_stack": { "type": "boolean" },
        "inline_parameter_sort_priority": { "type": "integer" },
        "editor_sort_priority": { "type": "integer" },
        "inline_edit_condition_toggle": { "type": "boolean" },
        "parent_attribute": { "type": "string" },
        "alternate_alias_count": { "type": "integer", "minimum": 0 },
        "property_metadata_count": { "type": "integer", "minimum": 0 }
      }
    },
    "niagara_script_ref": {
      "type": "object",
      "required": ["id", "index", "role", "script_path", "usage", "usage_id"],
      "properties": {
        "id": { "type": "string" },
        "index": { "type": "integer", "minimum": 0 },
        "role": { "type": "string" },
        "script_path": { "type": "string" },
        "usage": { "type": "string" },
        "usage_id": { "type": "string" }
      }
    },
    "niagara_renderer": {
      "type": "object",
      "required": ["id", "index", "name", "class", "is_enabled", "is_active", "sort_order_hint", "source_mode"],
      "properties": {
        "id": { "type": "string" },
        "index": { "type": "integer", "minimum": 0 },
        "name": { "type": "string" },
        "class": { "type": "string" },
        "is_enabled": { "type": "boolean" },
        "is_active": { "type": "boolean" },
        "sort_order_hint": { "type": "integer" },
        "source_mode": { "type": "integer" }
      }
    },
    "niagara_event_handler": {
      "type": "object",
      "required": [
        "id",
        "index",
        "source_event_name",
        "source_emitter_id",
        "execution_mode",
        "spawn_number",
        "max_events_per_frame",
        "random_spawn_number",
        "min_spawn_number",
        "update_attribute_initial_values",
        "script_usage_id"
      ],
      "properties": {
        "id": { "type": "string" },
        "index": { "type": "integer", "minimum": 0 },
        "source_event_name": { "type": "string" },
        "source_emitter_id": { "type": "string" },
        "execution_mode": { "type": "string" },
        "spawn_number": { "type": "integer", "minimum": 0 },
        "max_events_per_frame": { "type": "integer", "minimum": 0 },
        "random_spawn_number": { "type": "boolean" },
        "min_spawn_number": { "type": "integer", "minimum": 0 },
        "update_attribute_initial_values": { "type": "boolean" },
        "script_usage_id": { "type": "string" }
      }
    },
    "niagara_simulation_stage": {
      "type": "object",
      "required": ["id", "index", "name", "class", "is_enabled", "script_usage_id", "script_path"],
      "properties": {
        "id": { "type": "string" },
        "index": { "type": "integer", "minimum": 0 },
        "name": { "type": "string" },
        "class": { "type": "string" },
        "is_enabled": { "type": "boolean" },
        "script_usage_id": { "type": "string" },
        "script_path": { "type": "string" }
      }
    },
    "niagara_emitter": {
      "type": "object",
      "required": [
        "id",
        "schema_version",
        "source_layer",
        "emitter_path",
        "index",
        "name",
        "handle_id",
        "unique_instance_name",
        "is_enabled",
        "version_guid",
        "version_major",
        "version_minor",
        "deprecated",
        "local_space",
        "deterministic",
        "random_seed",
        "interpolated_spawning",
        "requires_persistent_ids",
        "sim_target",
        "bounds_mode",
        "preallocation_count",
        "allocation_mode",
        "renderer_count",
        "event_handler_count",
        "simulation_stage_count",
        "script_count",
        "renderers",
        "event_handlers",
        "simulation_stages",
        "scripts"
      ],
      "properties": {
        "id": { "type": "string" },
        "schema_version": { "const": "uepi.niagara_emitter.v1" },
        "source_layer": { "const": "uobject_reflection" },
        "emitter_path": { "type": "string" },
        "index": { "type": "integer", "minimum": 0 },
        "name": { "type": "string" },
        "handle_id": { "type": "string" },
        "unique_instance_name": { "type": "string" },
        "is_enabled": { "type": "boolean" },
        "version_guid": { "type": "string" },
        "version_major": { "type": "integer", "minimum": 0 },
        "version_minor": { "type": "integer", "minimum": 0 },
        "deprecated": { "type": "boolean" },
        "local_space": { "type": "boolean" },
        "deterministic": { "type": "boolean" },
        "random_seed": { "type": "integer" },
        "interpolated_spawning": { "type": "boolean" },
        "requires_persistent_ids": { "type": "boolean" },
        "sim_target": { "type": "string" },
        "bounds_mode": { "type": "string" },
        "preallocation_count": { "type": "integer", "minimum": 0 },
        "allocation_mode": { "type": "string" },
        "renderer_count": { "type": "integer", "minimum": 0 },
        "event_handler_count": { "type": "integer", "minimum": 0 },
        "simulation_stage_count": { "type": "integer", "minimum": 0 },
        "script_count": { "type": "integer", "minimum": 0 },
        "renderers": { "type": "array", "items": { "$ref": "#/$defs/niagara_renderer" } },
        "event_handlers": { "type": "array", "items": { "$ref": "#/$defs/niagara_event_handler" } },
        "simulation_stages": { "type": "array", "items": { "$ref": "#/$defs/niagara_simulation_stage" } },
        "scripts": { "type": "array", "items": { "$ref": "#/$defs/niagara_script_ref" } }
      }
    },
    "niagara_script": {
      "type": "object",
      "required": [
        "id",
        "schema_version",
        "source_layer",
        "script_path",
        "script_class",
        "usage",
        "usage_id",
        "compile_status",
        "vm_valid",
        "has_bytecode",
        "bytecode_length",
        "num_temp_registers",
        "num_user_pointers",
        "attribute_count",
        "data_interface_count",
        "uobject_reference_count",
        "called_vm_external_function_count",
        "read_dataset_count",
        "write_dataset_count",
        "simulation_stage_metadata_count",
        "last_op_count",
        "error_message",
        "rapid_iteration_parameter_count",
        "rapid_iteration_parameters"
      ],
      "properties": {
        "id": { "type": "string" },
        "schema_version": { "const": "uepi.niagara_script.v1" },
        "source_layer": { "const": "uobject_reflection" },
        "script_path": { "type": "string" },
        "script_class": { "type": "string" },
        "usage": { "type": "string" },
        "usage_id": { "type": "string" },
        "compile_status": { "type": "string" },
        "vm_valid": { "type": "boolean" },
        "has_bytecode": { "type": "boolean" },
        "bytecode_length": { "type": "integer", "minimum": 0 },
        "num_temp_registers": { "type": "integer", "minimum": 0 },
        "num_user_pointers": { "type": "integer", "minimum": 0 },
        "attribute_count": { "type": "integer", "minimum": 0 },
        "data_interface_count": { "type": "integer", "minimum": 0 },
        "uobject_reference_count": { "type": "integer", "minimum": 0 },
        "called_vm_external_function_count": { "type": "integer", "minimum": 0 },
        "read_dataset_count": { "type": "integer", "minimum": 0 },
        "write_dataset_count": { "type": "integer", "minimum": 0 },
        "simulation_stage_metadata_count": { "type": "integer", "minimum": 0 },
        "last_op_count": { "type": "integer", "minimum": 0 },
        "error_message": { "type": "string" },
        "rapid_iteration_parameter_count": { "type": "integer", "minimum": 0 },
        "rapid_iteration_parameters": { "type": "array", "items": { "$ref": "#/$defs/niagara_parameter" } }
      }
    },
    "niagara_system": {
      "type": "object",
      "required": [
        "schema_version",
        "source_layer",
        "system_path",
        "system_class",
        "is_valid",
        "is_ready_to_run",
        "needs_warmup",
        "warmup_time",
        "warmup_tick_count",
        "warmup_tick_delta",
        "fixed_tick_delta",
        "fixed_tick_delta_time",
        "deterministic",
        "random_seed",
        "fixed_bounds",
        "effect_type_path",
        "emitter_count",
        "system_script_count",
        "scripts",
        "user_parameter_count",
        "user_parameters",
        "emitters"
      ],
      "properties": {
        "schema_version": { "const": "uepi.niagara_system.v1" },
        "source_layer": { "const": "uobject_reflection" },
        "system_path": { "type": "string" },
        "system_class": { "type": "string" },
        "is_valid": { "type": "boolean" },
        "is_ready_to_run": { "type": "boolean" },
        "needs_warmup": { "type": "boolean" },
        "warmup_time": { "type": "number" },
        "warmup_tick_count": { "type": "integer", "minimum": 0 },
        "warmup_tick_delta": { "type": "number" },
        "fixed_tick_delta": { "type": "boolean" },
        "fixed_tick_delta_time": { "type": "number" },
        "deterministic": { "type": "boolean" },
        "random_seed": { "type": "integer" },
        "fixed_bounds": { "type": "boolean" },
        "effect_type_path": { "type": "string" },
        "emitter_count": { "type": "integer", "minimum": 0 },
        "system_script_count": { "type": "integer", "minimum": 0 },
        "scripts": { "type": "array", "items": { "$ref": "#/$defs/niagara_script_ref" } },
        "user_parameter_count": { "type": "integer", "minimum": 0 },
        "user_parameters": { "type": "array", "items": { "$ref": "#/$defs/niagara_parameter" } },
        "emitters": { "type": "array", "items": { "$ref": "#/$defs/niagara_emitter" } }
      }
    },
    "vector_field_static": {
      "type": "object",
      "required": [
        "schema_version",
        "source_layer",
        "vector_field_path",
        "vector_field_class",
        "size_x",
        "size_y",
        "size_z",
        "voxel_count",
        "intensity",
        "bounds_min",
        "bounds_max",
        "bounds_extent",
        "allow_cpu_access",
        "source_data_size_bytes",
        "has_cpu_data",
        "cpu_value_count"
      ],
      "properties": {
        "schema_version": { "const": "uepi.vector_field_static.v1" },
        "source_layer": { "const": "uobject_reflection" },
        "vector_field_path": { "type": "string" },
        "vector_field_class": { "type": "string" },
        "size_x": { "type": "integer", "minimum": 0 },
        "size_y": { "type": "integer", "minimum": 0 },
        "size_z": { "type": "integer", "minimum": 0 },
        "voxel_count": { "type": "integer", "minimum": 0 },
        "intensity": { "type": "number" },
        "bounds_min": { "$ref": "#/$defs/vector3" },
        "bounds_max": { "$ref": "#/$defs/vector3" },
        "bounds_extent": { "$ref": "#/$defs/vector3" },
        "allow_cpu_access": { "type": "boolean" },
        "source_data_size_bytes": { "type": "integer", "minimum": 0 },
        "has_cpu_data": { "type": "boolean" },
        "cpu_value_count": { "type": "integer", "minimum": 0 }
      }
    },
    "niagara_parameter_definitions": {
      "type": "object",
      "required": [
        "schema_version",
        "source_layer",
        "definitions_path",
        "definitions_class",
        "definitions_unique_id",
        "promote_to_top_in_add_menus",
        "menu_sort_order",
        "parameter_count",
        "parameters"
      ],
      "properties": {
        "schema_version": { "const": "uepi.niagara_parameter_definitions.v1" },
        "source_layer": { "const": "uobject_reflection" },
        "definitions_path": { "type": "string" },
        "definitions_class": { "type": "string" },
        "definitions_unique_id": { "type": "string" },
        "promote_to_top_in_add_menus": { "type": "boolean" },
        "menu_sort_order": { "type": "integer" },
        "parameter_count": { "type": "integer", "minimum": 0 },
        "parameters": { "type": "array", "items": { "$ref": "#/$defs/niagara_parameter_definition" } }
      }
    }
  }
}
